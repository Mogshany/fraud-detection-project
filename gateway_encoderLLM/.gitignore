*.pth
*.ckpt
ml_model/checkpoints/

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/settings.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
